generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String?
  emailVerified  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  websites       Website[]
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String    @id @default(cuid())
  email     String
  token     String
  type      TokenType @default(EMAIL_VERIFICATION)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
}

model Website {
  id           String      @id @default(cuid())
  userId       String
  slug         String      @unique
  title        String
  description  String?
  themeConfig  Json        // Stores {primaryColor, fontFamily, secondaryColor}
  isPublished  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages        Page[]
  blocks       PageBlock[]
  pageViews    Int         @default(0)  
}

model Page {
  id        String      @id @default(cuid())
  websiteId String
  slug      String
  title     String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  website   Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  blocks    PageBlock[]

  @@unique([websiteId, slug])
}

enum BlockType {
  HERO
  CATALOG
  CONTACT
  TEXT
  GALLERY
  // Structure
  DIV
  CMS
  COLUMN
  GRID
  LINK_BLOCK
  LIST
  CONTAINER
  // Typography
  HEADING
  PARAGRAPH
  QUOTE
  BUTTON
  // Media
  VIDEO
}

model PageBlock {
  id        String      @id @default(cuid())
  pageId    String
  websiteId String
  type      BlockType
  content   Json
  position  Json?       // Stores {x, y, width, height, zIndex}
  sortOrder Int
  parentId  String?
  createdAt DateTime    @default(now())
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  website   Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  parent    PageBlock?  @relation("BlockChildren", fields: [parentId], references: [id])
  children  PageBlock[] @relation("BlockChildren")
}
