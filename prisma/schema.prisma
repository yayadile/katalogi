generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserTier {
  FREE
  PAID
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          UserRole  @default(USER)
  tier          UserTier  @default(FREE)
  paidAt        DateTime?
  isSuspended   Boolean   @default(false)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  websites      Website[]
}

model VerificationToken {
  id        String    @id @default(cuid())
  email     String
  token     String
  type      TokenType @default(EMAIL_VERIFICATION)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
}

model Website {
  id          String      @id @default(cuid())
  userId      String
  slug        String      @unique
  title       String
  description String?
  themeConfig Json
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  pageViews   Int         @default(0)
  pages       Page[]
  blocks      PageBlock[]
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Page {
  id        String      @id @default(cuid())
  websiteId String
  slug      String
  title     String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  website   Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  blocks    PageBlock[]

  @@unique([websiteId, slug])
}

model PageBlock {
  id        String      @id @default(cuid())
  pageId    String
  websiteId String
  type      BlockType
  content   Json
  position  Json?
  sortOrder Int
  parentId  String?
  createdAt DateTime    @default(now())
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parent    PageBlock?  @relation("BlockChildren", fields: [parentId], references: [id])
  children  PageBlock[] @relation("BlockChildren")
  website   Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  content   String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum BlockType {
  HERO
  CATALOG
  CONTACT
  TEXT
  GALLERY
  DIV
  CMS
  COLUMN
  GRID
  LINK_BLOCK
  LIST
  CONTAINER
  HEADING
  PARAGRAPH
  QUOTE
  BUTTON
  VIDEO
}
