generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  websites     Website[]
}

model Website {
  id           String      @id @default(cuid())
  userId       String
  slug         String      @unique
  title        String
  description  String?
  themeConfig  Json        // Stores {primaryColor, fontFamily, secondaryColor}
  isPublished  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks       PageBlock[]
  pageViews    Int         @default(0)  
}

enum BlockType {
  HERO
  CATALOG
  CONTACT
  TEXT
  GALLERY
}

model PageBlock {
  id        String    @id @default(cuid())
  websiteId String
  type      BlockType
  content   Json
  sortOrder Int
  createdAt DateTime  @default(now())
  website   Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}
